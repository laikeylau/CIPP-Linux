# ============================================
# CIPP Linux Deployment - Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values.
# Required fields are marked with [REQUIRED].
#
# cp .env.example .env
# chmod 600 .env
# ============================================

# ==========================================
# CIPP API Credentials [REQUIRED]
# ==========================================
# These are the Azure AD App Registration credentials
# used by CIPP to access Microsoft 365 APIs (Graph, Exchange, etc.)
#
# APPLICATIONID:   Azure AD App Registration Application (client) ID
# APPLICATIONSECRET: Azure AD App Registration Client Secret
# REFRESHTOKEN:    OAuth2 Refresh Token for the CIPP service account
# TENANTID:        Your Microsoft 365 Tenant ID

APPLICATIONID=your-app-registration-client-id
APPLICATIONSECRET=your-app-registration-client-secret
REFRESHTOKEN=your-refresh-token
TENANTID=your-tenant-id

# ==========================================
# Azure Functions Runtime
# ==========================================
FUNCTIONS_WORKER_RUNTIME=powershell
FUNCTIONS_WORKER_RUNTIME_VERSION=7.4
FUNCTIONS_EXTENSION_VERSION=4

# ==========================================
# Azurite Storage Emulator
# ==========================================
# Default connection string for local Azurite emulator.
# Only change if you're using a remote Azurite instance.
# AZURE_WEB_JOBS_STORAGE=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNoBnZf6KgBVU4=;BlobEndpoint=http://azurite:10000/devstoreaccount1;QueueEndpoint=http://azurite:10001/devstoreaccount1;TableEndpoint=http://azurite:10002/devstoreaccount1;

# ==========================================
# Development Flags (optional)
# ==========================================
# Skip background timers during development
# DEV_SKIP_BPA_TIMER=true
# DEV_SKIP_DOMAIN_TIMER=true

# ==========================================
# SSL (optional)
# ==========================================
# Uncomment and set paths if using custom SSL certificates
# SSL_CERT_PATH=/path/to/fullchain.pem
# SSL_KEY_PATH=/path/to/privkey.pem
